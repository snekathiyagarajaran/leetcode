#include <string>
#include <vector>
#include <algorithm>
#include <numeric>
class Solution {
public:
    int minCut(std::string s) {
        int n = s.length();
        if (n <= 1) return 0;
        std::vector<int> cuts(n);
        for (int i = 0; i < n; ++i) {
            cuts[i] = i;
        }
        auto expandAroundCenter = [&](int left, int right) {
            while (left >= 0 && right < n && s[left] == s[right]) {
                int new_cut = (left == 0) ? 0 : cuts[left - 1] + 1;
                cuts[right] = std::min(cuts[right], new_cut);
                left--;
                right++;
            }
        };
        for (int i = 0; i < n; ++i) {
            expandAroundCenter(i, i);
            expandAroundCenter(i, i + 1);
        }
        return cuts[n - 1];
    }
};
