#include <vector>
#include <unordered_map>
#include <string>
#include <algorithm>
#include <numeric> 
class Solution {
public:
    int maxPoints(std::vector<std::vector<int>>& points) {
        int n = points.size();
        if (n <= 2) return n; 
        int global_max = 2; 
        for (int i = 0; i < n; ++i) {
            std::unordered_map<std::string, int> slope_map;
            int local_max = 0;
            for (int j = i + 1; j < n; ++j) {
                int dx = points[j][0] - points[i][0];
                int dy = points[j][1] - points[i][1];
                int g = std::gcd(dx, dy);
                dx /= g;
                dy /= g;
                if (dx < 0) {
                    dx = -dx;
                    dy = -dy;
                } else if (dx == 0) {
                    dy = 1;
                }
                std::string slope = std::to_string(dy) + "/" + std::to_string(dx);
                slope_map[slope]++;
                local_max = std::max(local_max, slope_map[slope]);
            }
            global_max = std::max(global_max, local_max + 1);
        }
        return global_max;
    }
};
