#include <vector>
#include <numeric>
class Solution {
public:
    int canCompleteCircuit(std::vector<int>& gas, std::vector<int>& cost) {
        int total_surplus = 0;
        int current_tank = 0;  
        int start_index = 0;   
        for (size_t i = 0; i < gas.size(); ++i) {
            int net_gas = gas[i] - cost[i];
            total_surplus += net_gas;
            current_tank += net_gas;
            if (current_tank < 0) {
                start_index = i + 1;
                current_tank = 0;
            }
        }
        return (total_surplus >= 0) ? start_index : -1;
    }
};
 
