#include <vector>
#include <algorithm>
#include <climits>
class Solution {
public:
    int maxProfit(std::vector<int>& prices) {
        int buy1 = INT_MAX;
        int profit1 = 0;
        int buy2 = INT_MAX;
        int profit2 = 0;
        for (int price : prices) {
            buy1 = std::min(buy1, price);
            profit1 = std::max(profit1, price - buy1);
            buy2 = std::min(buy2, price - profit1);
            profit2 = std::max(profit2, price - buy2);
        }
        return profit2;
    }
};
