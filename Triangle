#include <vector>
#include <algorithm>
class Solution {
public:
    int minimumTotal(std::vector<std::vector<int>>& triangle) {
        for (int row = (int)triangle.size() - 2; row >= 0; --row) {
            for (int col = 0; col <= row; ++col) {
                triangle[row][col] += std::min(triangle[row + 1][col], triangle[row + 1][col + 1]);
            }
        }
        return triangle[0][0];
    }
};
