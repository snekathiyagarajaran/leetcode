#include <stack>
class MinStack {
private:
    std::stack<int> main_stk;
    std::stack<int> min_stk;
public:
    MinStack() {
    }
    void push(int val) {
        main_stk.push(val);
        if (min_stk.empty() || val <= min_stk.top()) {
            min_stk.push(val);
        }
    }
    void pop() {
        if (main_stk.top() == min_stk.top()) {
            min_stk.pop();
        }
        main_stk.pop();
    }
    int top() {
        return main_stk.top();
    }
    int getMin() {
        return min_stk.top();
    }
};
