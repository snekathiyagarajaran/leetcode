#include <algorithm>
#include <climits>
class Solution {
private:
    int max_sum;
    int calculateMaxPath(TreeNode* node) {
        if (node == nullptr) return 0;
        int left_gain = std::max(0, calculateMaxPath(node->left));
        int right_gain = std::max(0, calculateMaxPath(node->right));
        int current_path_sum = node->val + left_gain + right_gain;
        max_sum = std::max(max_sum, current_path_sum);
        return node->val + std::max(left_gain, right_gain);
    }
public:
    int maxPathSum(TreeNode* root) {
        max_sum = INT_MIN; 
        calculateMaxPath(root);
        return max_sum;
    }
};
